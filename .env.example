# Grimoire engine environment
# Copy to .env and adjust for your setup

# ── Local mode (run on aid, direct KB access) ────────────────────────────────
GRIMOIRE_ROOT=/home/vgvm/eighty/data/grimoire-kb

# ── Remote mode (run from other hosts, requires grim serve on aid) ───────────
# GRIMOIRE_HOST=http://aid:3666

# ── AI ───────────────────────────────────────────────────────────────────────
# Ollama base URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# ── Server ───────────────────────────────────────────────────────────────────
# Port for grim-server (default: 3666)
GRIMOIRE_PORT=3666
