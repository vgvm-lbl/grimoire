# Grimoire engine environment
# Copy to .env and adjust for your setup

# Path to your grimoire-kb directory (required)
GRIMOIRE_ROOT=/mnt/eighty/userspace/vgvm/data/grimoire-kb

# Ollama base URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Grimoire server port (default: 3666)
GRIMOIRE_PORT=3666
