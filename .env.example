# Grimoire engine environment
# Copy to .env and adjust for your setup

# ── Local mode (run on aid, direct KB access) ────────────────────────────────
GRIMOIRE_ROOT=~/data/grimoire-kb

# ── Remote mode (run from other hosts, requires grim serve on aid) ───────────
# GRIMOIRE_HOST=http://aid:3663

# ── AI ───────────────────────────────────────────────────────────────────────
# Ollama base URL (default: http://localhost:11434)
# aid is the hostname of your local AI device (add it to /etc/hosts if needed)
OLLAMA_HOST=http://aid:11434

# ── Server ───────────────────────────────────────────────────────────────────
# Port for grim-server (default: 3663)
GRIMOIRE_PORT=3663
